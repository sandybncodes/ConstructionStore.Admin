## Ignore build outputs and local IDE state for the MAUI admin app.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.userprefs
*.sln.docstates

# IDE settings
.vs/
.vscode/
.idea/

# Build output
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Ll]og/
[Ll]ogs/

# Generated test and coverage output
[Tt]est[Rr]esult*/
coverage/
coverage*.json
coverage*.xml

# NuGet and local package artifacts
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets
artifacts/

# Windows packaging output
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle
*.appxupload

# Logs and caches
*.log
*.cache
Thumbs.db
Desktop.ini
.DS_Store