@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@inject AuthStateService Auth
@inject LocalizationService L10n

<div class="login-page">
    <div class="login-wrapper">

        <!-- Left branding panel -->
        <div class="brand-panel">
            <div class="brand-content">
                <div class="brand-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="white" viewBox="0 0 16 16">
                        <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5 8 5.961 14.154 3.5 8.186 1.113zM15 4.239l-6.5 2.6v7.922l6.5-2.6V4.24zm-7 10.5L1 12.16V4.24l7 2.6v7.899z" />
                    </svg>
                </div>
                <h1 class="brand-title">ConstructionStore</h1>
                <p class="brand-tagline">@L10n.T("login.portal")</p>
                <p class="brand-desc">@L10n.T("login.description")</p>

                <div class="brand-features">
                    <div class="feature-item">
                        <span class="feature-check">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z" />
                            </svg>
                        </span>
                        <span>@L10n.T("login.feature.catalogue")</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-check">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z" />
                            </svg>
                        </span>
                        <span>@L10n.T("login.feature.orders")</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-check">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z" />
                            </svg>
                        </span>
                        <span>@L10n.T("login.feature.security")</span>
                    </div>
                </div>
            </div>

            <div class="brand-footer">
                &copy; 2026 ConstructionStore. All rights reserved.
            </div>
        </div>

        <!-- Right form panel -->
        <div class="form-panel">
            <div class="form-card">

                <!-- Mobile-only logo -->
                <div class="mobile-logo">
                    <div class="mobile-logo-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="white" viewBox="0 0 16 16">
                            <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5 8 5.961 14.154 3.5 8.186 1.113zM15 4.239l-6.5 2.6v7.922l6.5-2.6V4.24zm-7 10.5L1 12.16V4.24l7 2.6v7.899z" />
                        </svg>
                    </div>
                    <span class="mobile-logo-text">ConstructionStore</span>
                </div>

                <div class="form-header">
                    <h2>@L10n.T("login.welcome")</h2>
                    <p>@L10n.T("login.subtitle")</p>
                </div>

                <form @onsubmit:preventDefault="true" @onsubmit="HandleLogin">

                    <!-- Email field -->
                    <div class="field-group">
                        <label class="field-label" for="email-input">@L10n.T("login.email")</label>
                        <div class="field-wrapper">
                            <span class="field-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z" />
                                </svg>
                            </span>
                            <input id="email-input" @bind="_model.Email" type="email"
                                class="field-input" placeholder="@L10n.T("login.emailPlaceholder")"
                                   autocomplete="email" />
                        </div>
                    </div>

                    <!-- Password field -->
                    <div class="field-group">
                        <label class="field-label" for="password-input">@L10n.T("login.password")</label>
                        <div class="field-wrapper">
                            <span class="field-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2" />
                                </svg>
                            </span>
                            <input id="password-input" @bind="_model.Password"
                                   type="@(_showPassword ? "text" : "password")"
                                   class="field-input field-input-padded" placeholder="@L10n.T("login.passwordPlaceholder")"
                                   autocomplete="current-password" />
                            <button type="button" class="field-toggle" @onclick="TogglePassword"
                                    title="@(_showPassword ? L10n.T("login.hidePassword") : L10n.T("login.showPassword"))">
                                @if (_showPassword)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z" />
                                        <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z" />
                                        <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12z" />
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                                    </svg>
                                }
                            </button>
                        </div>
                    </div>

                    <!-- Error alert -->
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="error-alert" role="alert">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="error-icon">
                                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2" />
                            </svg>
                            <span>@_errorMessage</span>
                        </div>
                    }

                    <!-- Submit button -->
                    <button type="submit" class="btn-signin" disabled="@_isLoading">
                        @if (_isLoading)
                        {
                            <div class="btn-spinner"></div>
                            <span>@L10n.T("login.signingIn")</span>
                        }
                        else
                        {
                            <span>@L10n.T("login.signIn")</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8" />
                            </svg>
                        }
                    </button>
                </form>

                <p class="form-footer">
                    @L10n.T("login.footer") &copy; 2026
                </p>
            </div>
        </div>

    </div>
</div>

@code {
    private readonly LoginModel _model = new();
    private bool _isLoading;
    private string? _errorMessage;
    private bool _showPassword;

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        var (success, error) = await Auth.LoginAsync(_model.Email, _model.Password);

        if (!success)
            _errorMessage = error;

        _isLoading = false;
    }

    private void TogglePassword() => _showPassword = !_showPassword;

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;
    }
}
