@page "/categories"
@inject CategoryService CategorySvc
@inject NavigationManager Nav
@inject LocalizationService L10n

<div class="sticky-list-header">
    <div class="page-header sticky-panel-card sticky-panel-card-top">
        <h2 class="page-title">@L10n.T("categories.title")</h2>
        <div class="page-header-actions">
            @if (!_loading)
            {
                <span class="page-count">@FilteredCategories.Count @L10n.T("categories.count")</span>
            }
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/categories/new")'>+ @L10n.T("categories.addNew")</button>
        </div>
    </div>

    <div class="list-toolbar sticky-panel-card sticky-panel-card-toolbar">
        <input class="search-input" @bind="_searchText" @bind:event="oninput" placeholder="@L10n.T("categories.search.placeholder")" />
    </div>
</div>

@if (_loading)
{
    <div class="loading-state">
        <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
        <span>@L10n.T("categories.loading")</span>
    </div>
}
else if (FilteredCategories.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">🗂️</div>
        <p>@L10n.T("categories.empty")</p>
    </div>
}
else
{
    <div class="category-grid">
        @foreach (var c in FilteredCategories)
        {
            <div class="category-card" @onclick="() => OpenCategory(c.Id)">
                <div class="category-icon">🏷️</div>
                <div class="category-info">
                    <div class="category-name">@c.Name</div>
                    <div class="category-id">@L10n.T("common.id"): @c.Id</div>
                    @if (!string.IsNullOrWhiteSpace(c.Description))
                    {
                        <div class="category-desc">@c.Description</div>
                    }
                    else
                    {
                        <div class="category-desc" style="font-style:italic">@L10n.T("common.noDescription")</div>
                    }
                </div>
                <div class="category-arrow">›</div>
            </div>
        }
    </div>
}

@code {
    private List<CategoryModel> _categories = new();
    private bool _loading = true;
    private string _searchText = string.Empty;

    private List<CategoryModel> FilteredCategories => _categories
        .Where(category =>
            string.IsNullOrWhiteSpace(_searchText) ||
            category.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            category.Id.ToString().Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .ToList();

    void OpenCategory(int id) => Nav.NavigateTo($"/categories/{id}");

    protected override async Task OnInitializedAsync()
    {
        _categories = await CategorySvc.GetCategoriesAsync();
        _loading = false;
    }
}
