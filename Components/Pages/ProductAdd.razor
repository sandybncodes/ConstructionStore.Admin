@page "/products/new"
@inject ProductService ProductSvc
@inject CategoryService CategorySvc
@inject NavigationManager Nav
@inject LocalizationService L10n
@inject ConstructionStore.Admin.Services.IImagePickerService ImagePicker
@using Microsoft.Maui.Storage

<div class="page-header">
    <button class="back-btn" @onclick="GoBack">← @L10n.T("common.back")</button>
    <h2 class="page-title">@L10n.T("products.addTitle")</h2>
</div>

@if (_loading)
{
    <div class="loading-state">
        <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
        <span>@L10n.T("common.loading")</span>
    </div>
}
else
{
    <!-- ── Product basics ──────────────────────────────── -->
    <div class="detail-card mb-3">
        <div class="detail-card-header">
            <div>
                <h3 class="detail-title">@L10n.T("products.addNew")</h3>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-secondary" @onclick="GoBack">@L10n.T("common.cancel")</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    💾 @L10n.T("common.save")
                </button>
            </div>
        </div>

        <div class="detail-body">
            <!-- Name & Category -->
            <div class="form-grid form-grid-2">
                <div class="form-group">
                    <label class="form-label">@L10n.T("common.name")</label>
                    <input class="form-control" @bind="_model.Name" />
                </div>
                <div class="form-group">
                    <label class="form-label">@L10n.T("common.category")</label>
                    <select class="form-select" @bind="_model.CategoryId">
                        <option value="">— @L10n.T("common.none") —</option>
                        @foreach (var category in _categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Description -->
            <div class="form-group mt-3">
                <label class="form-label">@L10n.T("common.description")</label>
                <textarea class="form-control" rows="3" @bind="_model.Description"></textarea>
            </div>

            <!-- Active toggle -->
            <div class="form-group mt-3">
                <label class="form-label">@L10n.T("common.active")</label>
                <div class="form-check form-switch mt-1">
                    <input class="form-check-input" type="checkbox" id="chkNewProductActive" @bind="_model.IsActive" />
                    <label class="form-check-label" for="chkNewProductActive">
                        @(_model.IsActive ? L10n.T("products.activeVisible") : L10n.T("products.inactiveHidden"))
                    </label>
                </div>
            </div>

            <!-- Images -->
            <div class="form-group mt-3">
                <label class="form-label">@L10n.T("common.images")</label>
                <div class="d-flex align-items-center gap-2 mt-1">
                    <button type="button" class="btn btn-outline-secondary" @onclick="PickImagesAsync">📷 @L10n.T("products.chooseImages")</button>
                    @if (_selectedImages.Count > 0)
                    {
                        <button type="button" class="btn btn-link btn-sm text-danger p-0" @onclick="ClearImages">@L10n.T("common.clear")</button>
                    }
                </div>
                <div class="form-text">@L10n.T("products.imagesHelp")</div>
                @if (_selectedImages.Count > 0)
                {
                    <div class="mt-2 small text-muted">@_selectedImages.Count @L10n.T("products.imagesSelected")</div>
                    <ul class="small mt-2 mb-0 ps-3">
                        @foreach (var image in _selectedImages)
                        {
                            <li>@image.FileName</li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <!-- ── Variants ──────────────────────────────────── -->
    <div class="detail-card mb-3">
        <div class="detail-card-header">
            <div>
                <h3 class="detail-title">@L10n.T("products.variants")</h3>
                <p class="detail-sub mb-0">@L10n.T("products.variantsHint")</p>
            </div>
            <button class="btn btn-outline-primary btn-sm" @onclick="AddVariant" disabled="@(_attributes.Count == 0)">
                + @L10n.T("products.addVariant")
            </button>
        </div>

        <div class="detail-body">
            @if (_attributes.Count == 0)
            {
                <div class="empty-state py-3">
                    <div class="empty-icon">⚠️</div>
                    <p class="mb-0">@L10n.T("products.attributesLoadFailed")</p>
                </div>
            }
            else if (_variants.Count == 0)
            {
                <div class="empty-state py-3">
                    <div class="empty-icon">📦</div>
                    <p class="mb-0 text-muted" style="font-size:0.9rem;">@L10n.T("products.variantsHint")</p>
                </div>
            }
            else
            {
                @for (int vi = 0; vi < _variants.Count; vi++)
                {
                    var idx = vi;
                    var variant = _variants[idx];
                    <div class="variant-card @(idx > 0 ? "mt-3" : "")">
                        <!-- Variant header -->
                        <div class="variant-card-header">
                            <span class="variant-number">@string.Format(L10n.T("products.variantNo"), idx + 1)</span>
                            <button type="button" class="btn btn-link btn-sm text-danger p-0 ms-auto" @onclick="() => RemoveVariant(idx)">
                                🗑 @L10n.T("products.removeVariant")
                            </button>
                        </div>

                        <!-- Price / Stock / Active -->
                        <div class="variant-card-body">
                            <div class="form-grid form-grid-2 mb-3">
                                <div class="form-group">
                                    <label class="form-label">@L10n.T("products.variantPrice")</label>
                                    <div class="input-group">
                                        <span class="input-group-text">@L10n.T("common.currency")</span>
                                        <input type="number" class="form-control" @bind="variant.Price" step="0.01" min="0" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">@L10n.T("products.variantStock")</label>
                                    <input type="number" class="form-control" @bind="variant.StockQuantity" min="0" />
                                </div>
                            </div>

                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" id="chkVariantActive_@idx" @bind="variant.IsActive" />
                                <label class="form-check-label" for="chkVariantActive_@idx">@L10n.T("products.variantActive")</label>
                            </div>

                            <!-- Attributes grid -->
                            <div class="detail-section-title">@L10n.T("products.variantAttributes")</div>
                            <div class="form-grid form-grid-2">
                                @foreach (var attrEntry in variant.AttributeEntries)
                                {
                                    <div class="form-group variant-attr-row">
                                        <label class="form-label variant-attr-label">@attrEntry.AttributeName</label>
                                        <div class="input-group input-group-sm">
                                            @if (IsNumericAttribute(attrEntry.AttributeName))
                                            {
                                                <input type="number"
                                                       class="form-control"
                                                       placeholder="@L10n.T("products.variantAttributeValue")"
                                                       step="any"
                                                       min="0"
                                                       @bind="attrEntry.ValueInput"
                                                       @bind:after="() => OnNumericValueChanged(attrEntry)" />
                                            }
                                            else
                                            {
                                                <input type="text"
                                                       class="form-control"
                                                       placeholder="@L10n.T("products.variantAttributeValue")"
                                                       @bind="attrEntry.ValueInput" />
                                            }
                                            @if (HasUnitDropdown(attrEntry.AttributeName))
                                            {
                                                <select class="form-select form-select-sm variant-unit-select @(attrEntry.ShowUnitError ? "is-invalid" : "")"
                                                        @onchange="e => OnUnitSelectChanged(e, attrEntry)">
                                                    <option value="—" selected="@(IsNoneUnit(attrEntry.Unit))">—</option>
                                                    @foreach (var opt in GetUnitOptions(attrEntry.AttributeName))
                                                    {
                                                        <option value="@opt" selected="@(attrEntry.Unit == opt)">@opt</option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <input type="text"
                                                       class="form-control variant-unit-input @(attrEntry.ShowUnitError ? "is-invalid" : "")"
                                                       placeholder="@L10n.T("products.variantAttributeUnit")"
                                                       value="@attrEntry.Unit"
                                                       @oninput="e => OnUnitInput(e, attrEntry)" />
                                            }
                                        </div>
                                        @if (attrEntry.ShowUnitError)
                                        {
                                            <small class="text-danger">@L10n.T("products.unitRequired")</small>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    @if (_saveMsg is not null)
    {
        <div class="status-toast @(_saveOk ? "toast-ok" : "toast-err")">@_saveMsg</div>
    }
}

@code {
    private static readonly HashSet<string> NumericAttributeNames = new(StringComparer.OrdinalIgnoreCase)
    {
        "Cantitate in ambalaj", "Grosime", "Latime", "Lungime", "Inaltime"
    };

    private static readonly Dictionary<string, string[]> UnitOptionsMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Latime"]               = new[] { "mm", "cm", "m" },
        ["Lungime"]              = new[] { "mm", "cm", "m" },
        ["Inaltime"]             = new[] { "mm", "cm", "m" },
        ["Grosime"]              = new[] { "mm", "cm" },
        ["Cantitate in ambalaj"] = new[] { "buc.", "g", "Kg" },
    };

    private static bool IsNumericAttribute(string name) => NumericAttributeNames.Contains(name);
    private static bool HasUnitDropdown(string name) => UnitOptionsMap.ContainsKey(name);
    private static string[] GetUnitOptions(string name) => UnitOptionsMap.TryGetValue(name, out var opts) ? opts : Array.Empty<string>();

    private static void OnNumericValueChanged(AttributeEntry entry)
    {
        if (string.IsNullOrWhiteSpace(entry.ValueInput))
            entry.ShowUnitError = false;
    }

    private static void OnUnitInput(ChangeEventArgs e, AttributeEntry entry)
    {
        entry.Unit = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(entry.Unit))
            entry.ShowUnitError = false;
    }

    private static bool IsNoneUnit(string? unit) => string.IsNullOrWhiteSpace(unit) || unit == "—";

    private static void OnUnitSelectChanged(ChangeEventArgs e, AttributeEntry entry)
    {
        entry.Unit = e.Value?.ToString() ?? "—";
        if (!IsNoneUnit(entry.Unit))
            entry.ShowUnitError = false;
    }

    private static bool ValidateNumericAttributeUnits(IEnumerable<AttributeEntry> entries)
    {
        var valid = true;
        foreach (var e in entries)
        {
            if (IsNumericAttribute(e.AttributeName))
            {
                if (!string.IsNullOrWhiteSpace(e.ValueInput) && IsNoneUnit(e.Unit))
                {
                    e.ShowUnitError = true;
                    valid = false;
                }
                else
                {
                    e.ShowUnitError = false;
                }
            }
        }
        return valid;
    }

    // ── Working models ──────────────────────────────────────────
    private sealed class AttributeEntry
    {
        public int AttributeId { get; set; }
        public string AttributeName { get; set; } = string.Empty;
        public string? ValueInput { get; set; }
        public string? Unit { get; set; }
        public bool ShowUnitError { get; set; }
    }

    private sealed class VariantForm
    {
        public decimal Price { get; set; }
        public int StockQuantity { get; set; }
        public string? Sku { get; set; }
        public bool IsActive { get; set; } = true;
        public List<AttributeEntry> AttributeEntries { get; set; } = new();
    }

    // ── State ───────────────────────────────────────────────────
    private readonly CreateProductDto _model = new() { IsActive = true };
    private List<CategoryModel> _categories = new();
    private List<AttributeModel> _attributes = new();
    private List<VariantForm> _variants = new();
    private List<FileResult> _selectedImages = new();
    private bool _loading = true;
    private bool _saving;
    private string? _saveMsg;
    private bool _saveOk;

    // ── Lifecycle ───────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var catTask = CategorySvc.GetCategoriesAsync();
        var attrTask = ProductSvc.GetAttributesAsync();
        await Task.WhenAll(catTask, attrTask);
        _categories = catTask.Result;
        _attributes = attrTask.Result;
        _loading = false;
    }

    // ── Navigation ──────────────────────────────────────────────
    private void GoBack() => Nav.NavigateTo("/products");

    // ── Images ──────────────────────────────────────────────────
    private void ClearImages() => _selectedImages.Clear();

    private async Task PickImagesAsync()
    {
        var picked = await ImagePicker.PickImagesAsync();
        if (picked is not null)
        {
            _selectedImages = picked.ToList();
        }
    }

    // ── Variants ────────────────────────────────────────────────
    private void AddVariant()
    {
        var form = new VariantForm();
        foreach (var attr in _attributes)
        {
            form.AttributeEntries.Add(new AttributeEntry
            {
                AttributeId = attr.Id,
                AttributeName = attr.Name,
                Unit = HasUnitDropdown(attr.Name) ? "—" : null
            });
        }
        _variants.Add(form);
    }

    private void RemoveVariant(int index)
    {
        if (index >= 0 && index < _variants.Count)
        {
            _variants.RemoveAt(index);
        }
    }

    // ── Save ────────────────────────────────────────────────────
    private async Task Save()
    {
        if (_saving) return;

        // Validate unit required for numeric attributes
        var allEntriesValid = true;
        foreach (var v in _variants)
        {
            if (!ValidateNumericAttributeUnits(v.AttributeEntries))
                allEntriesValid = false;
        }
        if (!allEntriesValid)
        {
            _saveMsg = L10n.T("products.unitRequired");
            _saveOk = false;
            StateHasChanged();
            await Task.Delay(3000);
            _saveMsg = null;
            StateHasChanged();
            return;
        }

        if (_selectedImages.Any(file => !IsSupportedImageFile(file)))
        {
            _saveMsg = L10n.T("products.imagesValidation");
            _saveOk = false;
            StateHasChanged();
            await Task.Delay(3000);
            _saveMsg = null;
            StateHasChanged();
            return;
        }

        _saving = true;
        StateHasChanged();

        // Build variants payload
        _model.Variants = _variants.Select(v => new CreateProductVariantDto
        {
            Price = v.Price,
            StockQuantity = v.StockQuantity,
            Sku = string.IsNullOrWhiteSpace(v.Sku) ? null : v.Sku.Trim(),
            IsActive = v.IsActive,
            Attributes = v.AttributeEntries
                .Where(a => !string.IsNullOrWhiteSpace(a.ValueInput))
                .Select(a =>
                {
                    var isNumeric = decimal.TryParse(
                        a.ValueInput?.Trim().Replace(',', '.'),
                        System.Globalization.NumberStyles.Any,
                        System.Globalization.CultureInfo.InvariantCulture,
                        out var numeric);
                    return new CreateVariantAttributeDto
                    {
                        AttributeId = a.AttributeId,
                        ValueNumeric = isNumeric ? numeric : null,
                        ValueText = isNumeric ? null : a.ValueInput?.Trim(),
                        Unit = IsNoneUnit(a.Unit) ? null : a.Unit!.Trim()
                    };
                })
                .ToList()
        }).ToList();

        var created = await ProductSvc.CreateProductAsync(_model);
        if (created is not null)
        {
            if (_selectedImages.Count > 0)
            {
                var uploadResult = await ProductSvc.UploadProductImagesAsync(created.Id, _selectedImages);
                _saveMsg = uploadResult.Success ? L10n.T("products.created") : L10n.T("products.imagesUploadFailed");
                _saveOk = uploadResult.Success;
            }
            else
            {
                _saveMsg = L10n.T("products.created");
                _saveOk = true;
            }

            _saving = false;
            StateHasChanged();
            await Task.Delay(900);
            Nav.NavigateTo($"/products/{created.Id}");
            return;
        }

        _saveMsg = L10n.T("products.createFailed");
        _saveOk = false;
        _saving = false;
        StateHasChanged();
        await Task.Delay(3000);
        _saveMsg = null;
        StateHasChanged();
    }

    private static bool IsSupportedImageFile(FileResult file)
    {
        var extension = Path.GetExtension(file.FileName);
        return extension.Equals(".jpg", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".jpeg", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".png", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".webp", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".gif", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".heic", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".heif", StringComparison.OrdinalIgnoreCase);
    }
}