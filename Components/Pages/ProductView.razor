@page "/products/{Id:int}"
@inject ProductService ProductSvc
@inject CategoryService CategorySvc
@inject NavigationManager Nav
@inject LocalizationService L10n
@inject ConstructionStore.Admin.Services.IImagePickerService ImagePicker
@using Microsoft.Maui.Storage

<div class="page-header">
    <button class="back-btn" @onclick="GoBack">← @L10n.T("common.back")</button>
    <h2 class="page-title">@L10n.T("products.details")</h2>
</div>

@if (_loading)
{
    <div class="loading-state">
        <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
        <span>@L10n.T("common.loading")</span>
    </div>
}
else if (_product is null)
{
    <div class="empty-state">
        <div class="empty-icon">🔍</div>
        <p>@L10n.T("products.notFound")</p>
    </div>
}
else
{
    <div class="detail-card">
        <div class="detail-card-header">
            <div>
                <h3 class="detail-title">@_product.Name</h3>
                <div class="detail-sub">@L10n.T("common.id"): @_product.Id · @L10n.T("products.addedOn") @L10n.FormatDate(_product.CreatedAt, "dd MMM yyyy")</div>
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (_product.IsActive)
                {
                    <span class="active-badge">@L10n.TranslateActiveState(true)</span>
                }
                else
                {
                    <span class="inactive-badge">@L10n.TranslateActiveState(false)</span>
                }
                @if (!_edit)
                {
                    <button class="btn btn-outline-primary" @onclick="() => _edit = true">✏️ @L10n.T("common.edit")</button>
                }
                else
                {
                    <button class="btn btn-secondary" @onclick="CancelEdit" disabled="@(_saving || _imageActionBusy)">@L10n.T("common.cancel")</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@(_saving || _imageActionBusy)">💾 @L10n.T("common.save")</button>
                }
            </div>
        </div>

        <div class="detail-body">
            <div class="product-detail-layout">
                <section class="product-gallery-panel">
                    @if (CurrentImages.Count == 0 && !_edit)
                    {
                        <div class="product-gallery-stage">
                            <img class="product-gallery-image" src="/images/repair_tools.png" alt="@_product.Name" />
                        </div>
                    }
                    @if (CurrentImages.Count > 0)
                    {
                        <div class="detail-section-title">@L10n.T("products.imagesGallery")</div>

                        @if (GetActiveImage() is { } activeImage)
                        {
                            <div class="product-gallery-stage">
                                <img class="product-gallery-image" src="@activeImage.ImageUrl" alt="@_product.Name" onerror="this.onerror=null;this.src='/images/repair_tools.png';" />

                                @if (CurrentImages.Count > 1)
                                {
                                    <button type="button" class="product-gallery-nav product-gallery-nav-prev" @onclick="ShowPreviousImage" aria-label="@L10n.T("products.previousImage")">
                                        ‹
                                    </button>
                                    <button type="button" class="product-gallery-nav product-gallery-nav-next" @onclick="ShowNextImage" aria-label="@L10n.T("products.nextImage")">
                                        ›
                                    </button>
                                    <div class="product-gallery-counter">@(_activeImageIndex + 1) / @CurrentImages.Count</div>
                                }
                            </div>
                        }

                        @if (CurrentImages.Count > 1)
                        {
                            <div class="product-gallery-thumbs" aria-label="@L10n.T("common.images")">
                                @for (var i = 0; i < CurrentImages.Count; i++)
                                {
                                    var imageIndex = i;
                                    var image = CurrentImages[imageIndex];
                                    var isActiveImage = imageIndex == _activeImageIndex;

                                    <button
                                        type="button"
                                        class="product-gallery-thumb @(isActiveImage ? "is-active" : null)"
                                        @onclick="() => SelectImage(imageIndex)"
                                        aria-label="@string.Format(L10n.T("products.viewImageNumber"), imageIndex + 1)">
                                        <img src="@image.ImageUrl" alt="" onerror="this.onerror=null;this.src='/images/repair_tools.png';" />
                                        @if (image.IsMain)
                                        {
                                            <span class="product-gallery-thumb-badge">@L10n.T("products.mainImage")</span>
                                        }
                                    </button>
                                }
                            </div>
                        }
                    }

                    @if (_edit)
                    {
                        <div class="product-image-manager">
                            <div class="product-image-manager-header">
                                <div>
                                    <div class="detail-section-title mb-2">@L10n.T("common.images")</div>
                                    <div class="product-image-manager-help">@L10n.T("products.imagesManagerHelp")</div>
                                </div>
                            </div>

                            @if (CurrentImages.Count == 0)
                            {
                                <div class="product-image-empty-list">@L10n.T("products.imagesEmpty")</div>
                            }
                            else
                            {
                                <div class="product-image-list">
                                    @for (var i = 0; i < CurrentImages.Count; i++)
                                    {
                                        var imageIndex = i;
                                        var image = CurrentImages[imageIndex];
                                        var isActiveImage = imageIndex == _activeImageIndex;

                                        <div class="product-image-row @(isActiveImage ? "is-active" : null)">
                                            <button type="button" class="product-image-preview" @onclick="() => SelectImage(imageIndex)" aria-label="@string.Format(L10n.T("products.viewImageNumber"), imageIndex + 1)">
                                                <img src="@image.ImageUrl" alt="" onerror="this.onerror=null;this.src='/images/repair_tools.png';" />
                                            </button>

                                            <div class="product-image-meta">
                                                <div class="product-image-title">@string.Format(L10n.T("products.imageNumber"), imageIndex + 1)</div>
                                                <div class="product-image-flags">
                                                    @if (image.IsMain)
                                                    {
                                                        <span class="product-image-flag">@L10n.T("products.mainImage")</span>
                                                    }
                                                    @if (isActiveImage)
                                                    {
                                                        <span class="product-image-flag product-image-flag-active">@L10n.T("products.currentImage")</span>
                                                    }
                                                </div>
                                            </div>

                                            <button
                                                type="button"
                                                class="btn btn-outline-danger btn-sm"
                                                @onclick="() => PromptDeleteImage(image.Id)"
                                                disabled="@(_imageActionBusy || _saving)">
                                                @L10n.T("common.delete")
                                            </button>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="product-image-upload-panel">
                                <label class="form-label">@L10n.T("products.addImages")</label>
                                <div class="d-flex align-items-center gap-2 mt-1">
                                    <button type="button" class="btn btn-outline-secondary" @onclick="PickImagesAsync" disabled="@(_imageActionBusy || _saving)">📷 @L10n.T("products.chooseImages")</button>
                                    @if (_selectedImages.Count > 0)
                                    {
                                        <button type="button" class="btn btn-link btn-sm text-danger p-0" @onclick="ClearSelectedImages" disabled="@(_imageActionBusy || _saving)">@L10n.T("common.clear")</button>
                                    }
                                </div>
                                <div class="form-text">@L10n.T("products.imagesHelp")</div>

                                @if (_selectedImages.Count > 0)
                                {
                                    <div class="mt-2 small text-muted">@_selectedImages.Count @L10n.T("products.imagesSelected")</div>
                                    <ul class="small mt-2 mb-0 ps-3">
                                        @foreach (var image in _selectedImages)
                                        {
                                            <li>@image.FileName</li>
                                        }
                                    </ul>
                                }

                                <div class="product-image-upload-actions">
                                    <button
                                        type="button"
                                        class="btn btn-outline-primary"
                                        @onclick="UploadImagesAsync"
                                        disabled="@(_imageActionBusy || _saving || _selectedImages.Count == 0)">
                                        @L10n.T("products.uploadImages")
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </section>

                <section class="product-form-panel">
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label class="form-label">@L10n.T("common.name")</label>
                            <input class="form-control" @bind="_editModel.Name" disabled="@(!_edit || _imageActionBusy)" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">@L10n.T("common.category")</label>
                            <select class="form-select" @bind="_editModel.CategoryId" disabled="@(!_edit || _imageActionBusy)">
                                <option value="">— @L10n.T("common.none") —</option>
                                @foreach (var c in _categories)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="form-group mt-3">
                        <label class="form-label">@L10n.T("common.description")</label>
                        <textarea class="form-control" rows="3" @bind="_editModel.Description" disabled="@(!_edit || _imageActionBusy)"></textarea>
                    </div>

                    <div class="form-group mt-3">
                        <label class="form-label">@L10n.T("common.active")</label>
                        <div class="form-check form-switch mt-1">
                            <input class="form-check-input" type="checkbox" id="chkActive" @bind="_editModel.IsActive" disabled="@(!_edit || _imageActionBusy)" />
                            <label class="form-check-label" for="chkActive">
                                @(_editModel.IsActive ? L10n.T("products.activeVisible") : L10n.T("products.inactiveHidden"))
                            </label>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>

    <!-- ── Variants ──────────────────────────────────── -->
    <div class="detail-card mt-3">
        <div class="detail-card-header">
            <div>
                <h3 class="detail-title">@L10n.T("products.variants")</h3>
                <p class="detail-sub mb-0">@L10n.T("products.variantsHint")</p>
            </div>
            @if (_edit)
            {
                <button class="btn btn-outline-primary btn-sm" @onclick="StartNewVariant"
                        disabled="@(_saving || _imageActionBusy || _newVariantForm is not null || _attributes.Count == 0)">
                    + @L10n.T("products.addVariant")
                </button>
            }
        </div>
        <div class="detail-body">
            @if (_variantForms.Count == 0)
            {
                <div class="empty-state py-3">
                    <div class="empty-icon">📦</div>
                    <p class="mb-0 text-muted" style="font-size:0.9rem;">@L10n.T("products.variantsHint")</p>
                </div>
            }
            else
            {
                @for (int vi = 0; vi < _variantForms.Count; vi++)
                {
                    var idx = vi;
                    var vf = _variantForms[idx];
                    <div class="variant-card @(idx > 0 ? "mt-3" : "")">
                        <div class="variant-card-header">
                            <span class="variant-number">@string.Format(L10n.T("products.variantNo"), idx + 1)</span>
                            <span class="variant-display-name">@VariantUtils.GetVariantDisplayName(_product!, _product!.Variants[idx])</span>
                            @if (_edit)
                            {
                                <button type="button" class="btn btn-link btn-sm text-danger p-0 ms-auto"
                                        @onclick="() => PromptDeleteVariant(vf.Id)"
                                        disabled="@(_saving || _imageActionBusy)">
                                    🗑 @L10n.T("products.removeVariant")
                                </button>
                            }
                            else
                            {
                                @if (vf.IsActive)
                                {
                                    <span class="active-badge ms-2">@L10n.TranslateActiveState(true)</span>
                                }
                                else
                                {
                                    <span class="inactive-badge ms-2">@L10n.TranslateActiveState(false)</span>
                                }
                            }
                        </div>
                        <div class="variant-card-body">
                            <div class="form-grid form-grid-2 mb-3">
                                <div class="form-group">
                                    <label class="form-label">@L10n.T("products.variantPrice")</label>
                                    <div class="input-group">
                                        <span class="input-group-text">@L10n.T("common.currency")</span>
                                        <input type="number" class="form-control" @bind="vf.Price" step="0.01" min="0" disabled="@(!_edit || _imageActionBusy)" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">@L10n.T("products.variantStock")</label>
                                    <input type="number" class="form-control" @bind="vf.StockQuantity" min="0" disabled="@(!_edit || _imageActionBusy)" />
                                </div>
                            </div>

                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" id="chkVfActive_@idx" @bind="vf.IsActive" disabled="@(!_edit || _imageActionBusy)" />
                                <label class="form-check-label" for="chkVfActive_@idx">@L10n.T("products.variantActive")</label>
                            </div>

                            <div class="detail-section-title">@L10n.T("products.variantAttributes")</div>
                            <div class="form-grid form-grid-2">
                                @foreach (var attrEntry in vf.AttributeEntries)
                                {
                                    <div class="form-group variant-attr-row">
                                        <label class="form-label variant-attr-label">@attrEntry.AttributeName</label>
                                        <div class="input-group input-group-sm">
                                            @if (IsNumericAttribute(attrEntry.AttributeName))
                                            {
                                                <input type="number"
                                                       class="form-control"
                                                       placeholder="@L10n.T("products.variantAttributeValue")"
                                                       step="any"
                                                       min="0"
                                                       @bind="attrEntry.ValueInput"
                                                       @bind:after="() => OnNumericValueChanged(attrEntry)"
                                                       disabled="@(!_edit || _imageActionBusy)" />
                                            }
                                            else
                                            {
                                                <input type="text"
                                                       class="form-control"
                                                       placeholder="@L10n.T("products.variantAttributeValue")"
                                                       @bind="attrEntry.ValueInput"
                                                       disabled="@(!_edit || _imageActionBusy)" />
                                            }
                                            @if (HasUnitDropdown(attrEntry.AttributeName))
                                            {
                                                <select class="form-select form-select-sm variant-unit-select @(attrEntry.ShowUnitError ? "is-invalid" : "")"
                                                        @onchange="e => OnUnitSelectChanged(e, attrEntry)"
                                                        disabled="@(!_edit || _imageActionBusy)">
                                                    <option value="—" selected="@(IsNoneUnit(attrEntry.Unit))">—</option>
                                                    @foreach (var opt in GetUnitOptions(attrEntry.AttributeName))
                                                    {
                                                        <option value="@opt" selected="@(attrEntry.Unit == opt)">@opt</option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <input type="text"
                                                       class="form-control variant-unit-input @(attrEntry.ShowUnitError ? "is-invalid" : "")"
                                                       placeholder="@L10n.T("products.variantAttributeUnit")"
                                                       value="@attrEntry.Unit"
                                                       @oninput="e => OnUnitInput(e, attrEntry)"
                                                       disabled="@(!_edit || _imageActionBusy)" />
                                            }
                                        </div>
                                        @if (attrEntry.ShowUnitError)
                                        {
                                            <small class="text-danger">@L10n.T("products.unitRequired")</small>
                                        }
                                    </div>
                                }
                            </div>

                            @if (_edit)
                            {
                                <div class="mt-3">
                                    <button class="btn btn-sm btn-primary"
                                            @onclick="() => SaveVariantAsync(idx)"
                                            disabled="@(_saving || _imageActionBusy)">
                                        @if (_saving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        }
                                        💾 @L10n.T("products.saveVariant")
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }
            }

            @if (_newVariantForm is not null)
            {
                var newIdx = _variantForms.Count;
                <div class="variant-card @(newIdx > 0 ? "mt-3" : "")">
                    <div class="variant-card-header">
                        <span class="variant-number">@string.Format(L10n.T("products.variantNo"), newIdx + 1)</span>
                        <button type="button" class="btn btn-link btn-sm text-danger p-0 ms-auto"
                                @onclick="CancelNewVariant" disabled="@_saving">
                            @L10n.T("common.cancel")
                        </button>
                    </div>
                    <div class="variant-card-body">
                        <div class="form-grid form-grid-2 mb-3">
                            <div class="form-group">
                                <label class="form-label">@L10n.T("products.variantPrice")</label>
                                <div class="input-group">
                                    <span class="input-group-text">@L10n.T("common.currency")</span>
                                    <input type="number" class="form-control" @bind="_newVariantForm.Price" step="0.01" min="0" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label">@L10n.T("products.variantStock")</label>
                                <input type="number" class="form-control" @bind="_newVariantForm.StockQuantity" min="0" />
                            </div>
                        </div>

                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="chkNewVfActive" @bind="_newVariantForm.IsActive" />
                            <label class="form-check-label" for="chkNewVfActive">@L10n.T("products.variantActive")</label>
                        </div>

                        <div class="detail-section-title">@L10n.T("products.variantAttributes")</div>
                        <div class="form-grid form-grid-2">
                            @foreach (var attrEntry in _newVariantForm.AttributeEntries)
                            {
                                <div class="form-group variant-attr-row">
                                    <label class="form-label variant-attr-label">@attrEntry.AttributeName</label>
                                    <div class="input-group input-group-sm">
                                        @if (IsNumericAttribute(attrEntry.AttributeName))
                                        {
                                            <input type="number" class="form-control"
                                                   placeholder="@L10n.T("products.variantAttributeValue")"
                                                   step="any"
                                                   min="0"
                                                   @bind="attrEntry.ValueInput"
                                                   @bind:after="() => OnNumericValueChanged(attrEntry)" />
                                        }
                                        else
                                        {
                                            <input type="text" class="form-control"
                                                   placeholder="@L10n.T("products.variantAttributeValue")"
                                                   @bind="attrEntry.ValueInput" />
                                        }
                                        @if (HasUnitDropdown(attrEntry.AttributeName))
                                        {
                                            <select class="form-select form-select-sm variant-unit-select @(attrEntry.ShowUnitError ? "is-invalid" : "")"
                                                    @onchange="e => OnUnitSelectChanged(e, attrEntry)">
                                                <option value="—" selected="@(IsNoneUnit(attrEntry.Unit))">—</option>
                                                @foreach (var opt in GetUnitOptions(attrEntry.AttributeName))
                                                {
                                                    <option value="@opt" selected="@(attrEntry.Unit == opt)">@opt</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <input type="text" class="form-control variant-unit-input @(attrEntry.ShowUnitError ? "is-invalid" : "")"
                                                   placeholder="@L10n.T("products.variantAttributeUnit")"
                                                   value="@attrEntry.Unit"
                                                   @oninput="e => OnUnitInput(e, attrEntry)" />
                                        }
                                    </div>
                                    @if (attrEntry.ShowUnitError)
                                    {
                                        <small class="text-danger">@L10n.T("products.unitRequired")</small>
                                    }
                                </div>
                            }
                        </div>

                        <div class="mt-3">
                            <button class="btn btn-sm btn-primary" @onclick="AddVariantAsync" disabled="@_saving">
                                @if (_saving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                }
                                💾 @L10n.T("products.saveVariant")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (_saveMsg is not null)
    {
        <div class="status-toast @(_saveOk ? "toast-ok" : "toast-err")">@_saveMsg</div>
    }

    @if (_pendingDeleteVariantId is not null)
    {
        <div class="dialog-backdrop" @onclick="CancelDeleteVariant">
            <div class="dialog-card" role="dialog" aria-modal="true" aria-labelledby="deleteVariantDialogTitle" @onclick:stopPropagation="true">
                <div class="dialog-icon">🗑️</div>
                <h4 class="dialog-title" id="deleteVariantDialogTitle">@L10n.T("products.deleteVariantTitle")</h4>
                <p class="dialog-text">@L10n.T("products.deleteVariantMessage")</p>
                <div class="dialog-actions">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDeleteVariant" disabled="@_saving">@L10n.T("common.cancel")</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteVariantAsync" disabled="@_saving">@L10n.T("products.deleteVariantConfirm")</button>
                </div>
            </div>
        </div>
    }

    @if (_pendingDeleteImageId is not null)
    {
        <div class="dialog-backdrop" @onclick="CancelDeleteImage">
            <div class="dialog-card" role="dialog" aria-modal="true" aria-labelledby="deleteImageDialogTitle" @onclick:stopPropagation="true">
                <div class="dialog-icon">🗑️</div>
                <h4 class="dialog-title" id="deleteImageDialogTitle">@L10n.T("products.deleteImageTitle")</h4>
                <p class="dialog-text">@L10n.T("products.deleteImageMessage")</p>
                <div class="dialog-actions">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDeleteImage" disabled="@_imageActionBusy">@L10n.T("common.cancel")</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteImageAsync" disabled="@_imageActionBusy">@L10n.T("products.deleteImageConfirm")</button>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private static readonly HashSet<string> NumericAttributeNames = new(StringComparer.OrdinalIgnoreCase)
    {
        "Cantitate in ambalaj", "Grosime", "Latime", "Lungime", "Inaltime"
    };

    private static readonly Dictionary<string, string[]> UnitOptionsMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Latime"]               = new[] { "mm", "cm", "m" },
        ["Lungime"]              = new[] { "mm", "cm", "m" },
        ["Inaltime"]             = new[] { "mm", "cm", "m" },
        ["Grosime"]              = new[] { "mm", "cm" },
        ["Cantitate in ambalaj"] = new[] { "buc.", "g", "Kg" },
    };

    private static bool IsNumericAttribute(string name) => NumericAttributeNames.Contains(name);
    private static bool HasUnitDropdown(string name) => UnitOptionsMap.ContainsKey(name);
    private static string[] GetUnitOptions(string name) => UnitOptionsMap.TryGetValue(name, out var opts) ? opts : Array.Empty<string>();

    private static void OnNumericValueChanged(AttributeEntry entry)
    {
        if (string.IsNullOrWhiteSpace(entry.ValueInput))
            entry.ShowUnitError = false;
    }

    private static void OnUnitInput(ChangeEventArgs e, AttributeEntry entry)
    {
        entry.Unit = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(entry.Unit))
            entry.ShowUnitError = false;
    }

    private static bool IsNoneUnit(string? unit) => string.IsNullOrWhiteSpace(unit) || unit == "—";

    private static void OnUnitSelectChanged(ChangeEventArgs e, AttributeEntry entry)
    {
        entry.Unit = e.Value?.ToString() ?? "—";
        if (!IsNoneUnit(entry.Unit))
            entry.ShowUnitError = false;
    }

    private static bool ValidateNumericAttributeUnits(IEnumerable<AttributeEntry> entries)
    {
        var valid = true;
        foreach (var e in entries)
        {
            if (IsNumericAttribute(e.AttributeName))
            {
                if (!string.IsNullOrWhiteSpace(e.ValueInput) && IsNoneUnit(e.Unit))
                {
                    e.ShowUnitError = true;
                    valid = false;
                }
                else
                {
                    e.ShowUnitError = false;
                }
            }
        }
        return valid;
    }

    private sealed class AttributeEntry
    {
        public int AttributeId { get; set; }
        public string AttributeName { get; set; } = string.Empty;
        public string? ValueInput { get; set; }
        public string? Unit { get; set; }
        public bool ShowUnitError { get; set; }
    }

    private sealed class VariantForm
    {
        public int Id { get; set; }
        public decimal Price { get; set; }
        public int StockQuantity { get; set; }
        public string? Sku { get; set; }
        public bool IsActive { get; set; } = true;
        public List<AttributeEntry> AttributeEntries { get; set; } = new();
    }

    private ProductModel? _product;
    private UpdateProductDto _editModel = new();
    private List<CategoryModel> _categories = new();
    private List<AttributeModel> _attributes = new();
    private List<VariantForm> _variantForms = new();
    private List<FileResult> _selectedImages = new();
    private bool _loading = true;
    private bool _edit;
    private bool _saving;
    private bool _imageActionBusy;
    private string? _saveMsg;
    private bool _saveOk;
    private int _activeImageIndex;
    private int? _pendingDeleteImageId;
    private int? _pendingDeleteVariantId;
    private VariantForm? _newVariantForm;
    private int _imageInputVersion;
    private IReadOnlyList<ProductImage> CurrentImages => _product?.Images ?? new List<ProductImage>();

    void GoBack() => Nav.NavigateTo("/products");

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    void CancelEdit()
    {
        _edit = false;
        if (_product is not null)
        {
            ApplyProductToEditModel(_product);
            BuildVariantForms(_product);
        }

        _selectedImages.Clear();
        _imageInputVersion++;
        _pendingDeleteImageId = null;
        _pendingDeleteVariantId = null;
        _newVariantForm = null;
    }

    async Task Save()
    {
        if (_product is null) return;

        _saving = true;
        var updated = await ProductSvc.UpdateProductAsync(_product.Id, _editModel);
        if (updated is not null)
        {
            _product = NormalizeProduct(updated);
            _edit = false;
            _selectedImages.Clear();
            SyncActiveImageIndex();
            _saving = false;
            await ShowStatusAsync(L10n.T("products.saved"), true);
        }
        else
        {
            _saving = false;
            await ShowStatusAsync(L10n.T("products.saveFailed"), false);
        }
    }

    private void ClearSelectedImages() => _selectedImages.Clear();

    private async Task PickImagesAsync()
    {
        var picked = await ImagePicker.PickImagesAsync();
        if (picked is not null)
        {
            _selectedImages = picked.ToList();
        }
    }

    private async Task UploadImagesAsync()
    {
        if (_product is null || _selectedImages.Count == 0)
        {
            return;
        }

        if (_selectedImages.Any(file => !IsSupportedImageFile(file)))
        {
            await ShowStatusAsync(L10n.T("products.imagesValidation"), false);
            return;
        }

        try
        {
            _imageActionBusy = true;

            var uploadResult = await ProductSvc.UploadProductImagesAsync(_product.Id, _selectedImages);
            if (uploadResult.Success)
            {
                await RefreshProductImagesAsync(_product.Id);
                _selectedImages.Clear();
                _imageInputVersion++;
                SyncActiveImageIndex();
                await ShowStatusAsync(L10n.T("products.imagesUploaded"), true);
            }
            else
            {
                await ShowStatusAsync(L10n.T("products.imagesUploadFailed"), false);
            }
        }
        catch
        {
            await ShowStatusAsync(L10n.T("products.imagesUploadFailed"), false);
        }
        finally
        {
            _imageActionBusy = false;
        }
    }

    private async Task DeleteImageAsync(int imageId)
    {
        if (_product is null)
        {
            return;
        }

        _imageActionBusy = true;

        var deleteResult = await ProductSvc.DeleteProductImageAsync(_product.Id, imageId);
        if (deleteResult.Success)
        {
            if (deleteResult.Product is not null)
            {
                if (_edit)
                {
                    _product.Images = OrderImages(deleteResult.Product.Images);
                }
                else
                {
                    _product = NormalizeProduct(deleteResult.Product);
                }
            }
            else
            {
                _product.Images = OrderImages(CurrentImages.Where(image => image.Id != imageId));
            }

            SyncActiveImageIndex();
            _imageActionBusy = false;
            await ShowStatusAsync(L10n.T("products.imageDeleted"), true);
        }
        else
        {
            _imageActionBusy = false;
            await ShowStatusAsync(L10n.T("products.imageDeleteFailed"), false);
        }
    }

    private void PromptDeleteImage(int imageId)
    {
        _pendingDeleteImageId = imageId;
    }

    private void CancelDeleteImage()
    {
        if (_imageActionBusy)
        {
            return;
        }

        _pendingDeleteImageId = null;
    }

    private async Task ConfirmDeleteImageAsync()
    {
        if (_pendingDeleteImageId is null)
        {
            return;
        }

        var imageId = _pendingDeleteImageId.Value;
        _pendingDeleteImageId = null;
        await DeleteImageAsync(imageId);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _saveMsg = null;

        var productTask = ProductSvc.GetProductAsync(Id);
        var categoriesTask = CategorySvc.GetCategoriesAsync();
        var attributesTask = ProductSvc.GetAttributesAsync();
        _product = NormalizeProduct(await productTask);
        _categories = await categoriesTask;
        _attributes = await attributesTask;

        if (_product is not null)
        {
            ApplyProductToEditModel(_product);
            BuildVariantForms(_product);
            SyncActiveImageIndex();
        }

        _loading = false;
    }

    private async Task RefreshProductImagesAsync(int productId)
    {
        var refreshedProduct = NormalizeProduct(await ProductSvc.GetProductAsync(productId));
        if (refreshedProduct is null || _product is null)
        {
            return;
        }

        _product.Images = refreshedProduct.Images;
        SyncActiveImageIndex();
    }

    private ProductImage? GetActiveImage()
    {
        if (CurrentImages.Count == 0)
        {
            return null;
        }

        SyncActiveImageIndex();
        return CurrentImages[_activeImageIndex];
    }

    private void SelectImage(int index)
    {
        if (index < 0 || index >= CurrentImages.Count)
        {
            return;
        }

        _activeImageIndex = index;
    }

    private void ShowPreviousImage()
    {
        if (CurrentImages.Count <= 1)
        {
            return;
        }

        _activeImageIndex = (_activeImageIndex - 1 + CurrentImages.Count) % CurrentImages.Count;
    }

    private void ShowNextImage()
    {
        if (CurrentImages.Count <= 1)
        {
            return;
        }

        _activeImageIndex = (_activeImageIndex + 1) % CurrentImages.Count;
    }

    private void SyncActiveImageIndex()
    {
        if (CurrentImages.Count == 0)
        {
            _activeImageIndex = 0;
            return;
        }

        if (_activeImageIndex < 0)
        {
            _activeImageIndex = 0;
        }
        else if (_activeImageIndex >= CurrentImages.Count)
        {
            _activeImageIndex = CurrentImages.Count - 1;
        }
    }

    private void ApplyProductToEditModel(ProductModel product)
    {
        _editModel = new UpdateProductDto
        {
            Name = product.Name,
            Description = product.Description,
            CategoryId = product.CategoryId,
            IsActive = product.IsActive
        };
    }

    private void BuildVariantForms(ProductModel product)
    {
        _variantForms = product.Variants.Select(v =>
        {
            var form = new VariantForm
            {
                Id = v.Id,
                Price = v.Price,
                StockQuantity = v.StockQuantity,
                Sku = v.Sku,
                IsActive = v.IsActive
            };

            foreach (var attr in _attributes)
            {
                var existing = v.Attributes.FirstOrDefault(a => a.AttributeId == attr.Id);
                form.AttributeEntries.Add(new AttributeEntry
                {
                    AttributeId = attr.Id,
                    AttributeName = attr.Name,
                    ValueInput = existing?.ValueNumeric?.ToString(System.Globalization.CultureInfo.InvariantCulture)
                                 ?? existing?.ValueText,
                    Unit = string.IsNullOrEmpty(existing?.Unit) ? (HasUnitDropdown(attr.Name) ? "—" : null) : existing.Unit
                });
            }

            return form;
        }).ToList();
    }

    private async Task SaveVariantAsync(int idx)
    {
        if (_product is null || idx < 0 || idx >= _variantForms.Count) return;
        if (_saving) return;

        var vf = _variantForms[idx];
        if (!ValidateNumericAttributeUnits(vf.AttributeEntries))
        {
            StateHasChanged();
            await ShowStatusAsync(L10n.T("products.unitRequired"), false);
            return;
        }

        _saving = true;
        StateHasChanged();

        var dto = new UpdateProductVariantDto
        {
            Price = vf.Price,
            StockQuantity = vf.StockQuantity,
            Sku = vf.Sku,
            IsActive = vf.IsActive,
            Attributes = vf.AttributeEntries
                .Where(e => !string.IsNullOrWhiteSpace(e.ValueInput))
                .Select(e => new UpdateVariantAttributeDto
                {
                    AttributeId = e.AttributeId,
                    ValueText = e.ValueInput,
                    Unit = IsNoneUnit(e.Unit) ? null : e.Unit
                })
                .ToList()
        };

        var updated = await ProductSvc.UpdateVariantAsync(_product.Id, vf.Id, dto);
        if (updated is not null)
        {
            _product = NormalizeProduct(updated);
            if (_product is not null) BuildVariantForms(_product);
            _saving = false;
            await ShowStatusAsync(L10n.T("products.variantSaved"), true);
        }
        else
        {
            _saving = false;
            await ShowStatusAsync(L10n.T("products.variantSaveFailed"), false);
        }
    }

    private void PromptDeleteVariant(int variantId)
    {
        _pendingDeleteVariantId = variantId;
    }

    private void CancelDeleteVariant()
    {
        if (_saving) return;
        _pendingDeleteVariantId = null;
    }

    private async Task ConfirmDeleteVariantAsync()
    {
        if (_pendingDeleteVariantId is null || _product is null) return;

        var variantId = _pendingDeleteVariantId.Value;
        _pendingDeleteVariantId = null;

        _saving = true;
        StateHasChanged();

        var (success, updated) = await ProductSvc.DeleteVariantAsync(_product.Id, variantId);
        if (success)
        {
            _product = NormalizeProduct(updated ?? _product);
            if (_product is not null) BuildVariantForms(_product);
            _saving = false;
            await ShowStatusAsync(L10n.T("products.variantDeleted"), true);
        }
        else
        {
            _saving = false;
            await ShowStatusAsync(L10n.T("products.variantDeleteFailed"), false);
        }
    }

    private void StartNewVariant()
    {
        if (_attributes.Count == 0) return;
        _newVariantForm = new VariantForm { IsActive = true };
        foreach (var attr in _attributes)
        {
            _newVariantForm.AttributeEntries.Add(new AttributeEntry
            {
                AttributeId = attr.Id,
                AttributeName = attr.Name,
                Unit = HasUnitDropdown(attr.Name) ? "—" : null
            });
        }
    }

    private void CancelNewVariant()
    {
        _newVariantForm = null;
    }

    private async Task AddVariantAsync()
    {
        if (_product is null || _newVariantForm is null) return;
        if (_saving) return;

        if (!ValidateNumericAttributeUnits(_newVariantForm.AttributeEntries))
        {
            StateHasChanged();
            await ShowStatusAsync(L10n.T("products.unitRequired"), false);
            return;
        }

        _saving = true;
        StateHasChanged();

        var dto = new CreateProductVariantDto
        {
            Price = _newVariantForm.Price,
            StockQuantity = _newVariantForm.StockQuantity,
            Sku = _newVariantForm.Sku,
            IsActive = _newVariantForm.IsActive,
            Attributes = _newVariantForm.AttributeEntries
                .Where(e => !string.IsNullOrWhiteSpace(e.ValueInput))
                .Select(e => new CreateVariantAttributeDto
                {
                    AttributeId = e.AttributeId,
                    ValueText = e.ValueInput,
                    Unit = IsNoneUnit(e.Unit) ? null : e.Unit
                })
                .ToList()
        };

        var updated = await ProductSvc.CreateVariantAsync(_product.Id, dto);
        if (updated is not null)
        {
            _product = NormalizeProduct(updated);
            if (_product is not null) BuildVariantForms(_product);
            _newVariantForm = null;
            _saving = false;
            await ShowStatusAsync(L10n.T("products.variantAdded"), true);
        }
        else
        {
            _saving = false;
            await ShowStatusAsync(L10n.T("products.variantAddFailed"), false);
        }
    }

    private static ProductModel? NormalizeProduct(ProductModel? product)
    {
        if (product is null)
        {
            return null;
        }

        product.Images = OrderImages(product.Images);
        return product;
    }

    private static List<ProductImage> OrderImages(IEnumerable<ProductImage> images)
    {
        return images
            .Where(image => image is not null)
            .Where(image => !string.IsNullOrWhiteSpace(image.ImageUrl))
            .OrderByDescending(image => image.IsMain)
            .ThenBy(image => image.Id)
            .ToList();
    }

    private async Task ShowStatusAsync(string message, bool success)
    {
        _saveMsg = message;
        _saveOk = success;
        StateHasChanged();
        await Task.Delay(3000);
        _saveMsg = null;
        StateHasChanged();
    }

    private static bool IsSupportedImageFile(FileResult file)
    {
        var extension = Path.GetExtension(file.FileName);
        return extension.Equals(".jpg", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".jpeg", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".png", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".webp", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".gif", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".heic", StringComparison.OrdinalIgnoreCase)
            || extension.Equals(".heif", StringComparison.OrdinalIgnoreCase);
    }
}
